# Chizhevsky Labs — Environment Variables
# Copy this file to .env and fill in your values

# NOAA/SWPC API (free, no key required — public endpoints)
NOAA_API_BASE=https://services.swpc.noaa.gov

# EAS Project ID (from eas.json after running `eas build:configure`)
EAS_PROJECT_ID=your-eas-project-id-here

# Optional: Future paid integrations
# CHANDELIER_IOT_API=https://api.chandelier.chizhevskylabs.com
# CHANDELIER_API_KEY=your-chandelier-api-key

# Optional: Analytics (privacy-respecting)
# ANALYTICS_ENABLED=false
